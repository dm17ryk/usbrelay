<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <UsbRelayVersion>1.0.0.7</UsbRelayVersion>
    <UsbRelayAssemblyTitle>USB-Relay Utility</UsbRelayAssemblyTitle>
    <UsbRelayDescription>A simple utility to control, list, and query USB-Relay devices.</UsbRelayDescription>
    <UsbRelayCompany>Min Xie (minxie.dallas@gmail.com)</UsbRelayCompany>
    <UsbRelayProduct>usbrelay</UsbRelayProduct>
    <UsbRelayCopyright>Copyright © 2021</UsbRelayCopyright>
    <UsbRelayInstallerDisplayName>USB-Relay Utility</UsbRelayInstallerDisplayName>
  </PropertyGroup>
</Project>
